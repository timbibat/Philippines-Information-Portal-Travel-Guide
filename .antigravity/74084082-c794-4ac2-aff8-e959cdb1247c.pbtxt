        lines {
          text: "    bestTime: \'March to June (Dry summer season)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Touring Marlboro Hills\', \'Viewing Basco Lighthouse\', \'Riding traditional Falua boats\', \'Meeting the welcoming Ivatan people\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'vigan\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Historic City of Vigan\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Ilocos Sur, Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A UNESCO World Heritage Site, Vigan is one of the best-preserved Spanish colonial towns in Asia. It is famous for its cobblestone streets, masterfully planned architecture merging Spanish, Chinese, and Filipino styles, and horse-drawn carriages (kalesas).\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Vigan was saved from destruction during WWII due to a romantic truce between a Japanese commander and a local priest.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'History\', \'Heritage\', \'Architecture\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'November to February (Cooler dry months)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Riding a Kalesa on Calle Crisologo\', \'Eating hot empanada at the plaza\', \'Trying traditional pottery at Pagburnayan\', \'Visiting Syquia Mansion\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
