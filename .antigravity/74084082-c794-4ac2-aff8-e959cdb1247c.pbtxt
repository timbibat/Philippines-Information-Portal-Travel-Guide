          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'el-nido\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'El Nido & Bacuit Archipelago\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Palawan, Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'World-renowned for its dramatic limestone cliffs rising straight out of turquoise lagoons. El Nido is the ultimate marine adventure gateway, blessed with white sand beaches, coral gardens, and hidden sinkhole tunnels.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'The limestone cliffs of El Nido are 250 million years old, dating back to the late Paleozoic and early Mesozoic eras.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Beach\', \'Nature\', \'Diving\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'December to May\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Kayaking in Big and Small Lagoon\', \'Snorkeling at Secret Lagoon\', \'Ziplining between Las Cabanas islets\', \'Sunbathing on Nacpan Beach\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'boracay\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Boracay Island\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Aklan, Western Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A tiny, butterfly-shaped island famous worldwide for its 4-kilometer stretching \"White Beach\" consisting of ultra-fine, cool-to-the-touch shell sand, spectacular sailing sunsets, and high-quality beachside hospitality.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Boracay underwent a legendary 6-month environmental rehabilitation in 2018, transforming its ecosystem back to its pristine historic state.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Beach\', \'Nightlife\', \'Lounge\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'November to May (Amihan season)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Paraw sailing at sunset\', \'Helmet diving\', \'Experiencing island beach walks\', \'Savoring fresh calamansi muffins\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'chocolate-hills\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Chocolate Hills\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Bohol, Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A geological anomaly of at least 1,260 symmetrical dome-shaped hills spreading over more than 50 square kilometers. They turn a dusty chocolate-brown color during the dry season, hence the name.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Local legend says the hills are tears of a giant named Arogo who wept over the death of his mortal lover, Aloya.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Adventure\', \'Nature\', \'Geology\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'January to May (Dry season to see them brown)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Viewing from Carmen peak\', \'Riding ATVs around the hill bases\', \'Visiting nearby Philippine Tarsier Sanctuary\', \'Cruising Loboc River\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
