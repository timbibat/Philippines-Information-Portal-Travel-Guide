        }
        lines {
          text: "    id: \'adobo\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Adobo\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    originalName: \'Adobong Pilipino\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pronunciation: \'ah-DOH-boh\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroupOrigin: \'Nationwide\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    flavorProfile: [\'Savory\', \'Sour\', \'Garlic\', \'Subtly Sweet\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    mainIngredients: [\'Pork or Chicken\', \'Vinegar (Suka)\', \'Soy Sauce\', \'Garlic\', \'Bay Leaves\', \'Black Peppercorns\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Often called the unofficial national dish of the Philippines. It consists of meat slow-stewed in vinegar, soy sauce, crushed garlic, bay leaves, and peppercorns, rendering a tender, intensely flavored comfort dish.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyAndCulture: \'Before refrigeration, indigenous Filipinos preserved meats using native vinegars and salt. When Spanish colonizers arrived, they observed this acid braise and named it \"adobo\" (from Spanish \"adobar\", to marinate), though the cooking method is purely pre-colonial.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cookingStyle: \'Meat is marinated and browned, then simmered slowly under low heat until the rich sauce is reduced and emulsifies in its own fat.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'sinigang\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Sinigang\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pronunciation: \'see-nee-GANG\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroupOrigin: \'Nationwide\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    flavorProfile: [\'Sour\', \'Savory\', \'Refreshing\', \'Spicy-Undertone\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    mainIngredients: [\'Pork, Shrimp, or Fish\', \'Tamarind (Sampalok)\', \'Taro (Gabi)\', \'Radish\', \'Kangkong (River Spinach)\', \'Long Green Chili\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A celebrated sour soup renowned for its refreshing, savory base. It showcases a diverse medley of indigenous vegetables like kangkong, long green chilies (sili), and eggplant, tied together by a lip-smacking tang.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyAndCulture: \'Voted multiple times as one of the best soups in the world, Sinigang reflects Filipino preferences for \"asim\" (sourness), which mimics refreshing properties ideal for hot tropical weather.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cookingStyle: \'Ingredients are boiled sequentially in a clear broth soured naturally by mashed real tamarind pods or local acidic fruits like batuan, bayabas (guava), or kamias.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'lechon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Lechon Cebu\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    originalName: \'Litson sa Sugbo\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pronunciation: \'leh-CHON\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroupOrigin: \'Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    flavorProfile: [\'Rich\', \'Salty\', \'Herby\', \'Crisp\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    mainIngredients: [\'Whole Roasting Pig\', \'Lemongrass (Tanglad)\', \'Spring Onions\', \'Garlic\', \'Star Anise\', \'Peppercorns\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'An iconic spit-roasted whole suckling pig, featuring shatteringly crisp golden-red skin and insanely juicy meat, heavily stuffed and perfumed with native lemongrass and herbs.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyAndCulture: \'Crowned by Anthony Bourdain as the \"best pig in the world,\" Lechon is the absolute centerpiece of Filipino fiestas, Christmas holiday feasts, and historic milestones.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cookingStyle: \'The cavity is filled with lemongrass, spring onions, and garlic, then skewered on a bamboo spit and hand-rotated over roaring red-hot coal embers for several hours.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'chicken-inasal\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Chicken Inasal\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pronunciation: \'ee-nah-SAL\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroupOrigin: \'Visayas\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    flavorProfile: [\'Citrusy\', \'Garlic\', \'Savory\', \'Smoky\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    mainIngredients: [\'Chicken cuts\', \'Calamansi\', \'Lemongrass\', \'Coconut Vinegar\', \'Annatto Oil (Atsuete)\', \'Garlic\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A distinct, smoky grilled chicken from Bacolod City. Unlike western barbecue, it is marinated in a special mixture of calamansi (local lime), lemongrass, ginger, and garlic, then basted with deep orange annatto seed oil.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyAndCulture: \'Originated in Negros Occidental, it is proof of how native citrus (calamansi) and seed oils (annatto) can create unparalleled charcoal-fired profiles.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cookingStyle: \'Basted continuously with annatto oil over blazing coals, lending its signature rich red-orange glaze and caramelized edges.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'halo-halo\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Halo-Halo\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pronunciation: \'HAH-loh HAH-loh\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroupOrigin: \'Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    flavorProfile: [\'Sweet\', \'Creamy\', \'Icy\', \'Vibrant\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    mainIngredients: [\'Shaved Ice\', \'Evaporated Milk\', \'Ube Halaya (Purple Yam)\', \'Leche Flan (Caramel Custard)\', \'Sweetened Bananas\', \'Jackfruit\', \'Nata de Coco\', \'Pinipig\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The ultimate colorful Filipino dessert! Meaning \"Mix-Mix,\" it is layer upon layer of sweet beans, gelatins, taro, jackfruit, topped with fluffy shaved ice, thick evaporated milk, a scoop of purple ube ice cream, and caramel flan.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyAndCulture: \'Evolved from Japanese pre-war migrants who brought \"mitsu mame\" (iced beans) to Manila. Filipinos hyper-customized it by piling fresh tropical fruits, ube, and rich Spanish-style egg pudding.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cookingStyle: \'Layered beautifully inside a tall clear glass, filled with shaved ice and dairy, and vigorously hand-stirred by the diner before consuming.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
