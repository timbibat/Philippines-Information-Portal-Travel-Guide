        lines {
          text: "    islandGroup: \'Luzon\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The northernmost province of the Philippines, characterized by rolling hills, steep cliffs, traditional stone houses built to withstand typhoons, deep blue waters, and a unique Ivatan culture.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Traditional Ivatan stone houses are bound with lime mortar and thatched with thick cogon grass to survive extreme oceanic winds.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Scenic\', \'Culture\', \'Highlands\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
