      replacement_content: "import { Globe, Compass, Utensils, Languages, HelpCircle, MessageSquareSparkles } from \'lucide-react\';\n\ninterface HeaderProps {\n  activeTab: string;\n  setActiveTab: (tab: string) => void;\n}\n\nexport default function Header({ activeTab, setActiveTab }: HeaderProps) {\n  const navItems = [\n    { id: \'explore\', label: \'Explore Regions\', icon: Compass },\n    { id: \'culinary\', label: \'Culinary Flavors\', icon: Utensils },\n    { id: \'phrasebook\', label: \'Local Phrasebook\', icon: Languages },\n    { id: \'quiz\', label: \'Trivia Challenge\', icon: HelpCircle },\n    { id: \'assistant\', label: \'AI Guide (Bayani)\', icon: MessageSquareSparkles },\n  ];\n\n  return (\n    <header className=\"sticky top-0 z-50 w-full border-b border-amber-100 bg-white/95 backdrop-blur-md\">\n      <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8\">\n        <div className=\"flex h-16 items-center justify-between\">\n          {/* Logo Brand */}\n          <div className=\"flex items-center gap-3 cursor-pointer\" onClick={() => setActiveTab(\'explore\')}>\n            <div className=\"flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-tr from-amber-500 via-emerald-500 to-sky-500 shadow-md\">\n              <Globe className=\"h-6 w-6 text-white\" />\n            </div>\n            <div>\n              <h1 className=\"font-sans text-lg font-bold tracking-tight text-slate-800 sm:text-xl\">\n                Mabuhay <span className=\"text-amber-600\">Pilipinas</span>\n              </h1>\n              <p className=\"font-mono text-[9px] uppercase tracking-widest text-slate-400\">\n                Philippine Discovery Portal\n              </p>\n            </div>\n          </div>\n\n          {/* Nav Links for Desktop */}\n          <nav className=\"hidden lg:flex lg:gap-x-1\">\n            {navItems.map((item) => {\n              const Icon = item.icon;\n              const isActive = activeTab === item.id;\n              return (\n                <button\n                  key={item.id}\n                  id={`nav-tab-${item.id}`}\n                  onClick={() => setActiveTab(item.id)}\n                  className={`flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium transition-all duration-200 ${\n                    isActive\n                      ? \'bg-amber-50 text-amber-700 shadow-sm shadow-amber-100\'\n                      : \'text-slate-600 hover:bg-slate-50 hover:text-slate-900\'\n                  }`}\n                >\n                  <Icon className={`h-4.5 w-4.5 ${isActive ? \'text-amber-600\' : \'text-slate-400\'}`} />\n                  {item.label}\n                </button>\n              );\n            })}\n          </nav>\n\n          {/* Mobile Badge / Country Info Overlay */}\n          <div className=\"flex items-center gap-2\">\n            <span className=\"inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 border border-emerald-100\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse\"></span>\n              7,641 Islands\n            </span>\n          </div>\n        </div>\n      </div>\n      \n      {/* Mobile Tab Selector Row (highly responsive horizontal scroll) */}\n      <div className=\"flex lg:hidden w-full overflow-x-auto border-t border-slate-100 bg-slate-50/50 scrollbar-none px-4 py-2 gap-2\">\n        {navItems.map((item) => {\n          const Icon = item.icon;\n          const isActive = activeTab === item.id;\n          return (\n            <button\n              key={item.id}\n              id={`nav-tab-mob-${item.id}`}\n              onClick={() => setActiveTab(item.id)}\n              className={`flex items-center gap-1.5 whitespace-nowrap rounded-md px-3 py-1.5 text-xs font-medium transition-all duration-150 ${\n                isActive\n                  ? \'bg-amber-500 text-white shadow-sm\'\n                  : \'bg-white text-slate-600 border border-slate-250/60 hover:bg-slate-50\'\n              }`}\n            >\n              <Icon className=\"h-3.5 w-3.5\" />\n              {item.label}\n            </button>\n          );\n        })}\n      </div>\n    </header>\n  );\n}\n"
    }
