        lines {
          text: "export const QUIZ_QUESTIONS: QuizQuestion[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'How many islands in total make up the Philippine Archipelago during high tide?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Around 7,107\', \'Exactly 10,000\', \'Around 7,641\', \'Around 3,500\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'In recent years, the National Mapping and Resource Information Authority (NAMRIA) updated the official count of islands of the Philippines to 7,641, discovering more coastal landmasses.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'Which volcano in the Philippines is famous for having a near-perfect symmetrical cone?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Mount Pinatubo\', \'Mount Mayon\', \'Taal Volcano\', \'Mount Pulag\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'Mount Mayon in Albay, Bicol, is world-famous for its majestic \"perfect cone\" structure, though it is also one of the country\\\'s most active volcanoes.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 3,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'What is the unofficial, internationally recognized national dish of the Philippines featuring slow-braised meat in soy and vinegar?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Lechon\', \'Adobo\', \'Kare-Kare\', \'Sinigang\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'Adobo is widely regarded as the unofficial national dish, showcasing pre-colonial vinegar braising techniques that preserve meat naturally in warm tropical climates.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 4,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'Which municipality in Bohol is famous for symmetrical green hills that turn brown in the dry season?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Carmen (Chocolate Hills)\', \'Panglao Island\', \'Loboc River\', \'Anda\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'The Chocolate Hills in Bohol (primarily viewed from the town of Carmen) consist of over 1,260 dome-shaped limestone hills that turn cocoa-brown during summer.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'What is the oldest Spanish colonial city in the Philippines, containing historic landmarks like Magellan\\\'s Cross?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Manila\', \'Vigan\', \'Cebu City\', \'Zamboanga\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'Cebu City is known as the \"Queen City of the South\" and is the oldest colonial city, established in 1565 by Miguel L\303\263pez de Legazpi following Magellan\\\'s initial landfall in 1521.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 6,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'What sweet, colorful dessert\\\'s name literally translates to \"Mix-Mix\" in English?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Leche Flan\', \'Bibingka\', \'Halo-Halo\', \'Sapin-Sapin\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 2,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'Halo-Halo literally means \"Mix-Mix\" in Tagalog because it requires diners to stir up layers of sweetened fruits, milk, ice, and ube before eating!\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: 7,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    question: \'Which island in Surigao del Norte is globally celebrated as the \"Surf Capital of the Philippines\"?\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    options: [\'Boracay\', \'Siargao\', \'Camiguin\', \'Samal\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    correctAnswerIndex: 1,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    explanation: \'Siargao is famous internationally as the Surf Capital of the country, home to the iconic \"Cloud 9\" wave which crashes over shallow coral reef flats.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
