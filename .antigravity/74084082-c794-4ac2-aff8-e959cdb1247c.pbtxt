    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { DISHES } from \'../data\';\nimport { Utensils, Award, Flame, Star, BookOpen, Volume2, PlusCircle, Check, Compass } from \'lucide-react\';\n\nexport default function CulinaryShowcase() {\n  const [selectedDishId, setSelectedDishId] = useState<string>(\'adobo\');\n  const [isPlayingAudio, setIsPlayingAudio] = useState<boolean>(false);\n  \n  // Flavor Matcher Simulator States\n  const [extraSourness, setExtraSourness] = useState<number>(50);\n  const [extraSweetness, setExtraSweetness] = useState<number>(10);\n  const [extraGarlic, setExtraGarlic] = useState<number>(80);\n\n  const activeDish = DISHES.find(d => d.id === selectedDishId)!;\n\n  const handlePlayPronunciation = () => {\n    setIsPlayingAudio(true);\n    setTimeout(() => {\n      setIsPlayingAudio(false);\n    }, 1200);\n  };\n\n  return (\n    <div className=\"space-y-12\">\n      {/* Intro section */}\n      <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n        <span className=\"inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 border border-emerald-200\">\n          <Utensils className=\"h-3.5 w-3.5 text-emerald-600\" />\n          Gastronomy Hub\n        </span>\n        <h2 className=\"text-3xl font-extrabold tracking-tight text-slate-800 sm:text-4xl\">\n          Flavors of the Archipelago\n        </h2>\n        <p className=\"text-slate-500 text-sm sm:text-base\">\n          Philippine cuisine is a complex sensory convergence of Austronesian roots, Spanish overlays, Chinese techniques, and American elements. Taste the bold, vinegar-cured, citrusy, and sweet layers.\n        </p>\n      </div>\n\n      <div className=\"grid lg:grid-cols-12 gap-8 items-start\">\n        {/* Left Hand selection column */}\n        <div className=\"lg:col-span-4 space-y-3\">\n          <p className=\"text-[11px] font-bold text-slate-400 uppercase tracking-widest pl-1 mb-2\">\n            Select a Celebrated Dish\n          </p>\n          <div className=\"grid grid-cols-2 lg:grid-cols-1 gap-2\">\n            {DISHES.map((dish) => {\n              const isSelected = selectedDishId === dish.id;\n              return (\n                <button\n                  key={dish.id}\n                  id={`dish-btn-${dish.id}`}\n                  onClick={() => {\n                    setSelectedDishId(dish.id);\n                    // Reset simulator variables appropriately\n                    if (dish.id === \'sinigang\') {\n                      setExtraSourness(90);\n                      setExtraSweetness(0);\n                    } else if (dish.id === \'halo-halo\') {\n                      setExtraSourness(0);\n                      setExtraSweetness(95);\n                    } else {\n                      setExtraSourness(40);\n                      setExtraSweetness(15);\n                    }\n                  }}\n                  className={`flex items-center justify-between p-4 rounded-xl border text-left transition-all ${\n                    isSelected\n                      ? \'bg-emerald-600 border-emerald-600 shadow-md shadow-emerald-600/10 text-white\'\n                      : \'bg-white border-slate-100 text-slate-700 hover:border-slate-300\'\n                  }`}\n                >\n                  <div className=\"space-y-0.5\">\n                    <p className=\"text-[10px] font-mono tracking-wider opacity-80 uppercase font-semibold\">\n                      {dish.islandGroupOrigin}\n                    </p>\n                    <p className=\"font-bold text-sm sm:text-base\">{dish.name}</p>\n                  </div>\n                  <ChevronDirectionIcon isSelected={isSelected} />\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Right hand layout detailed workspace */}\n        <div className=\"lg:col-span-8 bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden\">\n          {/* Accent Header */}\n          <div className=\"bg-gradient-to-r from-emerald-500 to-teal-600 p-6 text-white flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n            <div className=\"space-y-1\">\n              <span className=\"inline-flex items-center gap-1 rounded bg-emerald-700/50 px-2 py-0.5 text-[10px] font-bold tracking-wider uppercase\">\n                Native Origin: {activeDish.islandGroupOrigin}\n              </span>\n              <div className=\"flex items-center gap-3\">\n                <h3 className=\"text-2xl font-extrabold sm:text-3xl\">{activeDish.name}</h3>\n                {activeDish.originalName && (\n                  <span className=\"text-emerald-100 font-medium italic text-sm sm:text-base\">\n                    ({activeDish.originalName})\n                  </span>\n                )}\n              </div>\n            </div>\n\n            {/* Pronunciation triggers */}\n            <button\n              id=\"pronounce-trigger\"\n              onClick={handlePlayPronunciation}\n              className=\"flex items-center gap-2 rounded-full bg-white/20 px-4 py-2 text-xs font-semibold hover:bg-white/30 transition-all self-start sm:self-auto\"\n            >\n              <Volume2 className={`h-4.5 w-4.5 ${isPlayingAudio ? \'animate-bounce text-yellow-300\' : \'\'}`} />\n              <span className=\"font-mono text-emerald-50\">{activeDish.pronunciation}</span>\n            </button>\n          </div>\n\n          <div className=\"p-6 md:p-8 space-y-8\">\n            {/* Visual breakdown metrics */}\n            <div className=\"grid sm:grid-cols-2 gap-6 pb-2\">\n              {/* Flavor profiling list */}\n              <div className=\"space-y-2\">\n                <span className=\"text-xs font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5\">\n                  <Flame className=\"h-4 w-4 text-emerald-500\" /> Taste Anatomy\n                </span>\n                <div className=\"flex flex-wrap gap-1.5\">\n                  {activeDish.flavorProfile.map((flav, id) => (\n                    <span\n                      key={id}\n                      className=\"bg-emerald-50 text-emerald-800 text-xs font-semibold px-2.5 py-1 rounded-full border border-emerald-100\"\n                    >\n                      {flav}\n                    </span>\n                  ))}\n                </div>\n              </div>\n\n              {/* Main ingredient listing */}\n              <div className=\"space-y-2\">\n                <span className=\"text-xs font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5\">\n                  <Star className=\"h-4 w-4 text-amber-500\" /> Hero Ingredients\n                </span>\n                <div className=\"flex flex-wrap gap-1.5\">\n                  {activeDish.mainIngredients.map((ing, id) => (\n                    <span\n                      key={id}\n                      className=\"bg-slate-50 text-slate-700 text-xs font-medium px-2.5 py-1 rounded border border-slate-100\"\n                    >\n                      {ing}\n                    </span>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Story & Background */}\n            <div className=\"p-5 bg-gradient-to-br from-slate-50 to-emerald-50/10 border border-slate-100 rounded-xl space-y-3\">\n              <h4 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2\">\n                <BookOpen className=\"h-4 w-4 text-emerald-600\" />\n                Cultural & Ancient Heritage\n              </h4>\n              <p className=\"text-slate-600 text-xs sm:text-sm leading-relaxed\">\n                {activeDish.description}\n              </p>\n              <div className=\"h-px bg-slate-200/50 my-2\"></div>\n              <p className=\"text-slate-500 text-xs italic leading-relaxed\">\n                <span className=\"text-emerald-700 font-bold not-italic\">Did You Know?</span> {activeDish.historyAndCulture}\n              </p>\n            </div>\n\n            {/* Preparation / How to cook */}\n            <div className=\"space-y-3\">\n              <h4 className=\"text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2\">\n                <PlusCircle className=\"h-4 w-4 text-teal-600\" />\n                The Kitchen Craft (Preparation Style)\n              </h4>\n              <p className=\"text-slate-600 text-xs sm:text-sm leading-relaxed border-l-2 border-emerald-500 pl-4 py-0.5\">\n                {activeDish.cookingStyle}\n              </p>\n            </div>\n\n            {/* Dynamic Culinary Sandbox Interaction */}\n            <div className=\"border-t border-slate-100 pt-6 space-y-4\">\n              <div className=\"flex items-center justify-between\">\n                <div>\n                  <h4 className=\"text-sm font-bold text-slate-800 uppercase tracking-widest\">\n                    Flavor balance simulator\n                  </h4>\n                  <p className=\"text-[11px] text-slate-400\">\n                    Interact with the ingredients! Tweak ratios to preview how it shapes local palates:\n                  </p>\n                </div>\n                <span className=\"text-emerald-600 font-bold text-xs bg-emerald-50 inline-block px-2 py-0.5 rounded\">\n                  Interactive\n                </span>\n              </div>\n\n              <div className=\"grid gap-4 bg-slate-50 p-4 rounded-xl\">\n                {/* Sour */}\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between text-xs\">\n                    <span className=\"font-medium text-slate-600\">Sourness (Asim - Tamarind/Vinegar)</span>\n                    <span className=\"font-mono text-emerald-700 font-bold\">{extraSourness}%</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"100\"\n                    value={extraSourness}\n                    onChange={(e) => setExtraSourness(Number(e.target.value))}\n                    className=\"w-full accent-emerald-600 h-1 bg-slate-200 rounded-lg cursor-pointer\"\n                  />\n                </div>\n\n                {/* Garlic */}\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between text-xs\">\n                    <span className=\"font-medium text-slate-600\">Garlicky depth (Bawang)</span>\n                    <span className=\"font-mono text-emerald-700 font-bold\">{extraGarlic}%</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"100\"\n                    value={extraGarlic}\n                    onChange={(e) => setExtraGarlic(Number(e.target.value))}\n                    className=\"w-full accent-emerald-600 h-1 bg-slate-200 rounded-lg cursor-pointer\"\n                  />\n                </div>\n\n                {/* Sweet */}\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between text-xs\">\n                    <span className=\"font-medium text-slate-600\">Sweet undertone (Tamis)</span>\n                    <span className=\"font-mono text-emerald-700 font-bold\">{extraSweetness}%</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"0\"\n                    max=\"100\"\n                    value={extraSweetness}\n                    onChange={(e) => setExtraSweetness(Number(e.target.value))}\n                    className=\"w-full accent-emerald-600 h-1 bg-slate-200 rounded-lg cursor-pointer\"\n                  />\n                </div>\n              </div>\n\n              {/* Dynamic feedback display depending on slider setups */}\n              <div className=\"p-3.5 rounded-lg border text-xs bg-slate-50 border-slate-100 text-slate-500\">\n                <span className=\"font-bold text-slate-700\">Bayani\'s Taste Verdict: </span>\n                {extraSourness > 80 && extraSweetness < 15 ? (\n                  <span>\"Phew! That\'s beautifully tart (\'maasim\')! Perfect for a true rainy-day Sinigang of the Tagalog provinces!\"</span>\n                ) : extraSweetness > 85 && extraSourness < 15 ? (\n                  <span>\"Fabulous tamis! Reminds me of Cebu\'s Halo-Halo or Pampanga\'s caramelized Tocino. Super rich dessert vibes!\"</span>\n                ) : extraGarlic > 85 ? (\n                  <span>\"Oh yes! Thick, pungent garlic is the lifeblood of classic Adobo. This is going to toast perfectly over hot garlic rice!\"</span>\n                ) : (\n                  <span>\"A perfectly balanced, authentic Philippine profile (\'suwabeng timpla\'). Fits perfectly into any fiesta table across the islands!\"</span>\n                )}\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nfunction ChevronDirectionIcon({ isSelected }: { isSelected: boolean }) {\n  return (\n    <span\n      className={`h-5 w-5 rounded-full flex items-center justify-center transition-all ${\n        isSelected ? \'bg-white/20 text-white\' : \'bg-slate-100 text-slate-400\'\n      }`}\n    >\n      {isSelected ? (\n        <Check className=\"h-3 w-3 stroke-[3]\" />\n      ) : (\n        <span className=\"text-[14px]\">\342\206\222</span>\n      )}\n    </span>\n  );\n}\n"
    }
    overwrite: true
  }
}
