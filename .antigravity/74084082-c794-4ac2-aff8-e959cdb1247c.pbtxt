          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'siargao\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Siargao Island\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Surigao del Norte, Mindanao\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Mindanao\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The \"Surf Capital of the Philippines.\" A tear-shaped island in the Philippine Sea characterized by vast mangrove forests, pristine tidal rock pools, dense coconut roadways, and world-class reef break waters.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Siargao\\\'s famous wave is nicknamed \"Cloud 9\" because a traveling surfer named it after a popular local chocolate bar.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Surf\', \'Tropical\', \'Nature\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'August to November (Peak swells for surfing)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Surfing the Cloud 9 boardwalk reef\', \'Coconut grove swings at Maasin River\', \'Island-hopping to Naked, Daku & Guyam\', \'Swimming at Sugba Lagoon\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'camiguin\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Camiguin Island\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    location: \'Northern Mindanao\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    islandGroup: \'Mindanao\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Known as the \"Island Born of Fire\" due to its seven active volcanoes. This pear-shaped pearly island boasts bubbling sulfuric hot springs, refreshing cold soda springs, colonial ruins, and a Sunken Cemetery.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    funFact: \'Camiguin has more volcanoes per square kilometer than any other island on the planet.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tags: [\'Volcano\', \'Nature\', \'Wellness\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bestTime: \'May to October\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    activities: [\'Snorkeling at Sunken Cemetery\', \'Relaxing on the sandbar of White Island\', \'Bathing in Hibok-Hibok Ardent Hot Springs\', \'Admiring Katibawasan Falls\']"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "];"
