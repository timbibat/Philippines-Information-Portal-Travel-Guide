    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { ISLAND_GROUPS, DESTINATIONS } from \'../data\';\nimport { MapPin, Sun, Sparkles, BookOpen, ThumbsUp, Compass, Landmark } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\nexport default function RegionExplorer() {\n  const [selectedGroup, setSelectedGroup] = useState<\'luzon\' | \'visayas\' | \'mindanao\'>(\'luzon\');\n  const [activeDestinationId, setActiveDestinationId] = useState<string | null>(null);\n\n  const groupData = ISLAND_GROUPS.find(g => g.id === selectedGroup)!;\n  const filteredDestinations = DESTINATIONS.filter(\n    d => d.islandGroup.toLowerCase() === selectedGroup\n  );\n\n  return (\n    <div className=\"space-y-12\">\n      {/* Hero Intro */}\n      <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n        <span className=\"inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800 border border-amber-200\">\n          <Compass className=\"h-3.5 w-3.5 text-amber-600 animate-spin-slow\" />\n          Geographic Wonders\n        </span>\n        <h2 className=\"text-3xl font-extrabold tracking-tight text-slate-800 sm:text-4xl\">\n          Explore the Three Island Realms\n        </h2>\n        <p className=\"text-slate-500 text-sm sm:text-base\">\n          The Philippines is structured into three magnificent geographic divisions.\n          Journey through the volcanic peaks of Luzon, the sun-soaked shores of Visayas, and the ancestral woodlands of Mindanao.\n        </p>\n      </div>\n\n      {/* Tri-Island Group Selector (Large Tabs) */}\n      <div className=\"grid grid-cols-3 gap-2 max-w-3xl mx-auto bg-slate-100 p-1.5 rounded-xl border border-slate-250/20\">\n        {([\'luzon\', \'visayas\', \'mindanao\'] as const).map((id) => {\n          const group = ISLAND_GROUPS.find(g => g.id === id)!;\n          const isActive = selectedGroup === id;\n          return (\n            <button\n              key={id}\n              onClick={() => {\n                setSelectedGroup(id);\n                setActiveDestinationId(null);\n              }}\n              className={`relative py-3 px-2 sm:px-4 text-center rounded-lg font-bold text-sm transition-all focus:outline-none ${\n                isActive\n                  ? \'bg-white text-slate-800 shadow-md shadow-slate-200/50\'\n                  : \'text-slate-500 hover:text-slate-800 hover:bg-white/40\'\n              }`}\n            >\n              {group.name}\n              {isActive && (\n                <span className=\"absolute -bottom-1 left-1/2 -translate-x-1/2 w-4 h-1 bg-amber-500 rounded-full\" />\n              )}\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Main Island Group Detailed Profile */}\n      <div className=\"bg-white rounded-2xl border border-slate-100 p-6 md:p-8 shadow-sm\">\n        <div className=\"grid md:grid-cols-12 gap-8 items-start\">\n          {/* Text Summary */}\n          <div className=\"md:col-span-7 space-y-6\">\n            <div className=\"space-y-2\">\n              <p className=\"font-mono text-xs font-bold uppercase tracking-wider text-amber-600\">\n                {groupData.tagline}\n              </p>\n              <h3 className=\"text-2xl font-bold text-slate-800 sm:text-3xl\">\n                The Realm of {groupData.name}\n              </h3>\n            </div>\n            <p className=\"text-slate-600 text-sm leading-relaxed sm:text-base\">\n              {groupData.description}\n            </p>\n\n            {/* Sub-lists: climate & dialects */}\n            <div className=\"grid sm:grid-cols-2 gap-4 pt-2\">\n              <div className=\"p-4 bg-slate-50 rounded-xl space-y-1\">\n                <span className=\"flex items-center gap-1.5 text-xs font-bold text-slate-500 uppercase tracking-widest\">\n                  <Sun className=\"h-4 w-4 text-amber-500\" /> Climate Profile\n                </span>\n                <p className=\"text-slate-700 text-xs sm:text-sm font-medium\">\n                  {groupData.climate}\n                </p>\n              </div>\n              <div className=\"p-4 bg-slate-50 rounded-xl space-y-1\">\n                <span className=\"flex items-center gap-1.5 text-xs font-bold text-slate-500 uppercase tracking-widest\">\n                  <BookOpen className=\"h-4 w-4 text-emerald-500\" /> Major Languages\n                </span>\n                <p className=\"text-slate-700 text-xs sm:text-sm font-medium\">\n                  {groupData.nativeLanguages.join(\', \')}\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* Quick Provinces List Card */}\n          <div className=\"md:col-span-5 bg-gradient-to-br from-slate-50 to-amber-50/20 border border-slate-100 rounded-xl p-6\">\n            <h4 className=\"flex items-center gap-2 text-sm font-bold text-slate-700 uppercase tracking-wider mb-4 pb-2 border-b border-slate-200/50\">\n              <Landmark className=\"h-4 w-4 text-amber-600\" />\n              Provinces & Hubs\n            </h4>\n            <div className=\"flex flex-wrap gap-2\">\n              {groupData.majorProvinces.map((province, idx) => (\n                <span\n                  key={idx}\n                  className=\"inline-flex items-center rounded-md bg-white px-2.5 py-1 text-xs font-medium text-slate-600 border border-slate-200/60 shadow-sm\"\n                >\n                  {province}\n                </span>\n              ))}\n            </div>\n            <div className=\"mt-6 pt-4 border-t border-slate-200/40 text-center\">\n              <p className=\"text-[11px] text-slate-400 italic\">\n                The Philippine archipelago features 82 provinces across 17 administrative regions.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Destinations Showcase Title */}\n      <div className=\"space-y-4\">\n        <div className=\"flex items-center gap-2\">\n          <div className=\"h-px bg-slate-200 flex-1\"></div>\n          <p className=\"font-sans font-bold text-xs uppercase tracking-widest text-slate-400 text-center px-4\">\n            Must-Visit Destinations in {groupData.name}\n          </p>\n          <div className=\"h-px bg-slate-200 flex-1\"></div>\n        </div>\n\n        {/* Destination Cards Grid */}\n        <div className=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filteredDestinations.map((dest) => {\n            const isExpanded = activeDestinationId === dest.id;\n            return (\n              <div\n                key={dest.id}\n                id={`dest-card-${dest.id}`}\n                className={`bg-white rounded-xl border transition-all duration-300 flex flex-col h-full overflow-hidden ${\n                  isExpanded \n                    ? \'border-amber-300 shadow-md shadow-amber-500/5 col-span-1 md:col-span-2 lg:col-span-1\' \n                    : \'border-slate-100 hover:border-slate-300 hover:shadow-sm\'\n                }`}\n              >\n                {/* Visual Header bar style */}\n                <div className=\"h-2 bg-gradient-to-r from-amber-500 via-emerald-500 to-sky-500\"></div>\n\n                {/* Body */}\n                <div className=\"p-6 flex-1 flex flex-col justify-between space-y-4\">\n                  <div className=\"space-y-2\">\n                    <div className=\"flex flex-wrap items-center gap-2 justify-between\">\n                      <span className=\"inline-flex items-center gap-1 text-[11px] font-bold text-slate-400 uppercase tracking-wider\">\n                        <MapPin className=\"h-3 w-3 text-red-500\" /> {dest.location}\n                      </span>\n                      <span className=\"inline-flex rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-semibold text-amber-800 border border-amber-100 uppercase\">\n                        {dest.bestTime}\n                      </span>\n                    </div>\n                    <h5 className=\"text-xl font-bold text-slate-800\">{dest.name}</h5>\n                    <p className=\"text-slate-500 text-xs sm:text-sm line-clamp-3 leading-relaxed\">\n                      {dest.description}\n                    </p>\n                  </div>\n\n                  {/* Highlights/Tags */}\n                  <div className=\"flex flex-wrap gap-1.5\">\n                    {dest.tags.map((tag, i) => (\n                      <span\n                        key={i}\n                        className=\"bg-slate-100 text-slate-600 text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider\"\n                      >\n                        #{tag}\n                      </span>\n                    ))}\n                  </div>\n\n                  {/* Dynamic Accordion Section */}\n                  {isExpanded && (\n                    <div className=\"pt-4 border-t border-slate-100 space-y-4 animate-fadeIn\">\n                      {/* Activities */}\n                      <div className=\"space-y-1.5\">\n                        <p className=\"text-xs font-bold text-slate-600 uppercase tracking-widest flex items-center gap-1\">\n                          <Sparkles className=\"h-3.5 w-3.5 text-amber-500\" /> Key Experiences\n                        </p>\n                        <ul className=\"grid grid-cols-1 sm:grid-cols-2 gap-1 px-1\">\n                          {dest.activities.map((act, i) => (\n                            <li key={i} className=\"text-xs text-slate-500 flex items-start gap-1\">\n                              <span className=\"text-amber-500 text-[12px]\">\342\200\242</span> <span>{act}</span>\n                            </li>\n                          ))}\n                        </ul>\n                      </div>\n\n                      {/* Fun Fact Yellow Post-It Card */}\n                      <div className=\"p-4 bg-amber-50/60 rounded-lg border-l-4 border-amber-400 space-y-1\">\n                        <p className=\"text-xs font-bold text-amber-900 uppercase tracking-wider flex items-center gap-1\">\n                          <ThumbsUp className=\"h-3 w-3 text-amber-600\" /> Local Secret\n                        </p>\n                        <p className=\"text-xs text-slate-600 leading-relaxed italic\">\n                          \"{dest.funFact}\"\n                        </p>\n                      </div>\n                    </div>\n                  )}\n\n                  {/* Action Button to Expand Details */}\n                  <button\n                    onClick={() => setActiveDestinationId(isExpanded ? null : dest.id)}\n                    className={`mt-4 w-full text-center py-2 text-xs font-bold rounded-lg border transition-colors ${\n                      isExpanded\n                        ? \'border-slate-200 bg-slate-50 text-slate-500 hover:bg-slate-100\'\n                        : \'border-amber-200 bg-amber-50/50 text-amber-700 hover:bg-amber-50\'\n                    }`}\n                  >\n                    {isExpanded ? \'Hide Details\' : \'Discover Experiences & Facts\'}\n                  </button>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
